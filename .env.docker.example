APP_NAME="Gestão de Despesas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://IP-DO-SEU-SERVIDOR

LOG_CHANNEL=stack
LOG_LEVEL=error

# Banco de dados — defina senhas fortes
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=expense_manager
DB_USERNAME=expense_user
DB_PASSWORD=TrocaPorUmaSenhaForte123!
DB_ROOT_PASSWORD=TrocaPorUmaRootSenhaForte456!

# Fila de jobs (e-mails)
QUEUE_CONNECTION=database

# Storage
FILESYSTEM_DISK=public

# Sessão
SESSION_DRIVER=database
SESSION_LIFETIME=480

# Cache
CACHE_DRIVER=file

# E-mail (configure com seu SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@email.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=seu@email.com
MAIL_FROM_NAME="Gestão de Despesas"
